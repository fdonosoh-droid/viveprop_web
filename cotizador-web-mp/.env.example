# ============================================================
# VARIABLES DE ENTORNO — Cotizador Web Mercado Primario
# Copiar a .env.local y completar con valores reales
# .env.local está en .gitignore — NUNCA subir al repositorio
# ============================================================

# ── Fuente de datos ─────────────────────────────────────────
# 'excel'    → ExcelAdapter (desarrollo, lee INPUT_FILES.xlsx)
# 'postgres' → PgAdapter (producción, requiere DATABASE_URL)
DATA_SOURCE=excel

# ── PostgreSQL (solo si DATA_SOURCE=postgres) ───────────────
# Formato: postgresql://usuario:contraseña@host:puerto/basedatos
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/cotizador

# ── Email (SMTP) ────────────────────────────────────────────
# Proveedor: cualquier servidor SMTP (Gmail, Outlook, Mailgun, etc.)
# Para Gmail: habilitar "Contraseña de aplicación" en la cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=usuario@gmail.com
SMTP_PASS=contraseña_de_aplicacion
# Remitente que aparece en el campo "From"
EMAIL_FROM="Cotizador MP <cotizaciones@empresa.cl>"

# ── CMF Chile — API valor UF (producción) ───────────────────
# Registrarse en: https://api.cmfchile.cl/
# Si no se configura, el sistema usa el último valor en la base de datos
CMF_API_KEY=tu_api_key_cmf

# ── Opcionales ──────────────────────────────────────────────
# NODE_ENV=production  # Next.js lo maneja automáticamente
